# ============================================================
#  EndoScan AI — sozlamalar SHABLONI (namuna)
#  Bu faylni nusxa oling va ".env" deb nomlang, keyin
#  haqiqiy qiymatlar bilan to'ldiring.
#  Buyruq:  cp .env.example .env   (Windows:  copy .env.example .env)
# ============================================================

# Google Gemini API kaliti — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# JWT imzolash kaliti — kuchli tasodifiy qiymat qo'ying.
# Generatsiya qilish (Linux):  openssl rand -hex 32
JWT_SECRET_KEY=

# Standart admin akkaunti
ENDOSCAN_ADMIN_USERNAME=admin
ENDOSCAN_ADMIN_PASSWORD=

# Java statistika servisi manzili
JAVA_STATS_BASE_URL=http://127.0.0.1:8081
